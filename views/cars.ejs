<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Dealership | Cars</title>
    <%- include('./partials/styles-head.ejs') %>
</head>

<body>
    <%- include('./partials/navbar.ejs') %>
        <div class="container">
            <!-- Header Section -->
            <h1 class="display-4 mb-4">Cars</h1>

            <!-- Collapse button to expand filter section -->
            <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#filter-section"
                aria-expanded="false" aria-controls="filter-section">
                Filter results
            </button>
            <!-- Collapsable area -->
            <div class="collapse" id="filter-section">
                <!-- Filter Section -->
                <form class="container bg-dark text-light p-2 rounded" action="/cars" method="get">
                    <h3 class="h3">Search</h3>
                    <div class="d-flex flex-row">
                        <!-- Filter keywords -->
                        <div class="container">
                            <h4>Filter:</h4>
                            <div class="mb-3">
                                <label class="form-label">Brand</label>
                                <input class="form-control" type="text" name="brand" placeholder="honda">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Model</label>
                                <input class="form-control" type="text" name="model" placeholder="civic">
                            </div>
                        </div>

                        <!-- Select the order -->
                        <div class="container">
                            <h4>Order:</h4>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="order" value="ascending" checked>
                                <label class="form-check-label">A - Z ↓</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="order" value="descending">
                                <label class="form-check-label">Z - A ↑</label>
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-primary" type="submit">Apply filter</button>
                </form>
            </div>

            <i class="muted"><%= cars.length %> Results</i>

            <!-- Car List Section -->
            <% if (cars.length===0) { %>
                <i>Sold out! ⚠️</i>
                <form action="/populate/cars" method="post">
                    <button type="submit">Add Car Data</button>
                </form>

                <% } else { %>
                    <ul>
                        <% cars.forEach(c=> { %>
                            <li>
                                <a href="/cars/<%= c.id %>">
                                    <%= c.brand %>
                                        <%= c.model %> (<%= c.year %>)
                                </a>
                            </li>
                            <% }) %>
                    </ul>
                    <% } %>
        </div>

        <div class="container">
            <form action="/cars" method="get">
                <label class="d-inline form-label ">Number of results per page: </label>
                <input class="d-inline form-control " type="number" name="limit">
                <button class="btn btn-primary" type="submit">Ok</button>
            </form>
        </div>

        <!-- Pagination section -->
        <nav aria-label="Page navigation example">
            <ul class="pagination">
                <!-- <li class="page-item"><a class="page-link" href="/cars/?page=">Previous</a></li> -->
                <li class="page-item"><a class="page-link" href="/cars/?page=1&brand=<%= brandFilter %>&model=<%= modelFilter %>&order=<%= order %>&limit=<%= limit %>">1</a></li>
                <li class="page-item"><a class="page-link" href="/cars/?page=2&brand=<%= brandFilter %>&model=<%= modelFilter %>&order=<%= order %>&limit=<%= limit %>">2</a></li>
                <% if (cars.length <= limit) { %>
                    <li class="page-item"><a class="page-link" href="/cars/?page=3&brand=<%= brandFilter %>&model=<%= modelFilter %>&order=<%= order %>&limit=<%= limit %>">3</a></li>
                <% } else { %>
                    <li class="page-item disabled"><a class="page-link" href="/cars/?page=3&brand=<%= brandFilter %>&model=<%= modelFilter %>&order=<%= order %>&limit=<%= limit %>">3</a></li>
                <% } %>
                <!-- <li class="page-item"><a class="page-link" href="/cars/?page=">Next</a></li> -->
            </ul>
        </nav>            

        <%- include('./partials/scripts.ejs') %>
</body>

</html>